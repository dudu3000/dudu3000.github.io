<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | CuratStralucitor</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar.ejs') %>

    <main>
        <!-- Page Header -->
        <section class="page-header">
            <h1>Cunoaștete Echipa Noastră</h1>
            <p>Doi profesioniști dedicați devoțiunii voastre curăției</p>
        </section>

        <!-- Team Section -->
        <section class="team-section">
            <div class="team-grid">
                <% employees.forEach((employee, index) => { %>
                    <div class="team-card employee-card-<%= index + 1 %>">
                        <div class="team-image-wrapper">
                            <div class="team-image">
                                <!-- Placeholder: Replace with actual image path -->
                                <div class="image-placeholder">
                                    <span class="emoji">👩‍💼</span>
                                </div>
                            </div>
                            <div class="team-overlay">
                                <span class="star">⭐</span>
                            </div>
                        </div>
                        <div class="team-content">
                            <h3><%= employee.name %></h3>
                            <p class="bio"><%= employee.bio %></p>
                            <div class="skills">
                                <span class="skill-tag">Profesionist</span>
                                <span class="skill-tag">Experimentat</span>
                                <span class="skill-tag">De Încredere</span>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <!-- Why They're Great -->
        <section class="team-values">
            <h2>Angajamentul Nostru</h2>
            <div class="values-grid">
                <div class="value-item">
                    <div class="value-icon">🎯</div>
                    <h4>Calitate pe Primul Loc</h4>
                    <p>Credem că fiecare detaliu contează și ne dedic\u0103m perfecțiunii în fiecare spațiu pe care îl curățim</p>
                </div>
                <div class="value-item">
                    <div class="value-icon">💪</div>
                    <h4>Serviciu Dedicat</h4>
                    <p>Echipa noastră depășește așteptările pentru a asigura satisfacția clienților și rezultate excepționale</p>
                </div>
                <div class="value-item">
                    <div class="value-icon">🌟</div>
                    <h4>Standarde Profesionale</h4>
                    <p>Menținem cele mai înalte standarde din industrie în toate practicile și echipamentele noastre de curățenie</p>
                </div>
                <div class="value-item">
                    <div class="value-icon">🤝</div>
                    <h4>Centrat pe Client</h4>
                    <p>Satisfacția voastră este prioritatea noastră și ascultăm nevoile și preferințele voastre specifice</p>
                </div>
            </div>
        </section>

        <!-- Experience & Skills -->
        <section class="experience-section">
            <h2>Expertiza Noastră</h2>
            <div class="expertise-container">
                <div class="expertise-item">
                    <h4>Experiență Combinată</h4>
                    <p class="big-number">14+ Ani</p>
                    <p>În servicii profesionale de curățenie</p>
                </div>
                <div class="expertise-item">
                    <h4>Servicii Oferite</h4>
                    <p class="big-number">6+</p>
                    <p>Servicii de curățenie speciale diferite</p>
                </div>
                <div class="expertise-item">
                    <h4>Satisfacția Clientului</h4>
                    <p class="big-number">100%</p>
                    <p>Angajament pentru excelență</p>
                </div>
                <div class="expertise-item">
                    <h4>Echipament & Produse</h4>
                    <p class="big-number">Premium</p>
                    <p>Instrumente de clasă profesională și produse ecologice</p>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="cta">
            <h2>Gata să Experimentați Curățenie Profesională?</h2>
            <p>Contactați echipa noastră astăzi</p>
            <a href="/contact" class="btn btn-large">Contactați-ne</a>
        </section>
    </main>

    <%- include('includes/footer.ejs') %>

    <script src="/js/main.js"></script>
</body>
</html>
