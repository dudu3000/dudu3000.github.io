<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | CuratStralucitor</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar.ejs') %>

    <main>
        <!-- Page Header -->
        <section class="page-header">
            <h1>Lucrările Noastre</h1>
            <p>Vedeți transformarea pe care o creăm pentru clienții noștri</p>
        </section>

        <!-- Gallery Grid -->
        <section class="gallery-section">
            <div class="gallery-container">
                <% gallery.forEach((item, index) => { %>
                    <div class="gallery-item gallery-item-<%= index + 1 %>">
                        <div class="gallery-image">
                            <!-- Placeholder: Replace with actual image -->
                            <div class="image-placeholder-large">
                                <span class="emoji" style="font-size: 3rem;">📸</span>
                                <p><%= item.title %></p>
                            </div>
                        </div>
                        <div class="gallery-overlay">
                            <h4><%= item.title %></h4>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <!-- Gallery Info -->
        <section class="gallery-info">
            <h2>Rezultate Înainte & După</h2>
            <p>Răsfoiți portofoliul nostru pentru a vedea calitatea lucrării pe care o livrăm. Fiecare spațiu a fost transformat cu grijă și atenție la detalii.</p>
            <div class="info-boxes">
                <div class="info-box">
                    <h4>🏆 Lucrări de Calitate</h4>
                    <p>Rezultate profesionale pe care le puteți vedea și simți</p>
                </div>
                <div class="info-box">
                    <h4>✨ Atenție la Detalii</h4>
                    <p>Fiecare colț curat în profunzime</p>
                </div>
                <div class="info-box">
                    <h4>💯 Rezultate Dovedite</h4>
                    <p>Transformări reale de la clienți reali</p>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="cta">
            <h2>Impresionat de Lucrările Noastre?</h2>
            <p>Permiteți-ne să aducem aceeași calitate în spațiul vostru</p>
            <a href="/contact" class="btn btn-large">Rezervați Serviciul Nostru</a>
        </section>
    </main>

    <%- include('includes/footer.ejs') %>

    <script src="/js/main.js"></script>
</body>
</html>
