<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | CuratStralucitor</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar.ejs') %>

    <main>
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <div class="hero-text">
                    <h1 class="hero-title">Servicii Profesionale de <span class="gradient-text">Curățenie</span></h1>
                    <p class="hero-subtitle">Transformăm spațiile în medii curate și liniștite</p>
                    <div class="hero-buttons">
                        <a href="/services" class="btn btn-primary">Vezi Serviciile</a>
                        <a href="/contact" class="btn btn-secondary">Cere o Ofertă</a>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="floating-card">
                        <div class="card-content">
                            <span class="icon">✨</span>
                            <h3>Calitate Garantată</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="animated-bg"></div>
        </section>

        <!-- Features Section -->
        <section class="features">
            <h2>De ce să alegi CuratStralucitor</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">🏠</div>
                    <h3>Echipă Expertă</h3>
                    <p>Doi profesioniști dedicați cu ani de experiență</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">⚡</div>
                    <h3>Serviciu Rapid</h3>
                    <p>Curățiere eficientă și promptă fără a compromite calitatea</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🌱</div>
                    <h3>Eco-Friendly</h3>
                    <p>Folosim soluții de curățenie durabile și sigure</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">💰</div>
                    <h3>Prețuri Accesibile</h3>
                    <p>Prețuri competitive cu oferte transparente</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔒</div>
                    <h3>De Încredere</h3>
                    <p>Serviciu sigur pe care puteți să vă bazați</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">⏰</div>
                    <h3>Program Flexibil</h3>
                    <p>Disponibili pentru comoditatea voastră, chiar și în weekenduri</p>
                </div>
            </div>
        </section>

        <!-- Services Preview -->
        <section class="services-preview">
            <h2>Serviciile Noastre</h2>
            <div class="services-display">
                <div class="service-item">
                    <span class="service-emoji">🏢</span>
                    <h4>Apartamente</h4>
                </div>
                <div class="service-item">
                    <span class="service-emoji">🏡</span>
                    <h4>Case</h4>
                </div>
                <div class="service-item">
                    <span class="service-emoji">🏢</span>
                    <h4>Birouri</h4>
                </div>
            </div>
            <a href="/services" class="btn btn-primary">Vezi Toate Serviciile și Prețurile</a>
        </section>

        <!-- CTA Section -->
        <section class="cta">
            <h2>Gata pentru un Spațiu Imaculat?</h2>
            <p>Contactați-ne astăzi pentru soluții de curățenie personalizate</p>
            <a href="/contact" class="btn btn-large">Puneți-ne la Curent</a>
        </section>
    </main>

    <%- include('includes/footer.ejs') %>

    <script src="/js/main.js"></script>
</body>
</html>
