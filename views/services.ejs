<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | CuratStralucitor</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('includes/navbar.ejs') %>

    <main>
        <!-- Services Header -->
        <section class="page-header">
            <h1>Serviciile și Prețurile Noastre</h1>
            <p>Curățenie profesională adaptată nevoilor voastre</p>
        </section>

        <!-- Pricing Cards -->
        <section class="pricing-section">
            <div class="pricing-grid">
                <% services.forEach((service, index) => { %>
                    <div class="pricing-card service-card-<%= index + 1 %>">
                        <div class="card-header">
                            <h3><%= service.name %></h3>
                        </div>
                        <div class="card-price">
                            <span class="price"><%= service.price %></span>
                        </div>
                        <div class="card-description">
                            <p><%= service.description %></p>
                        </div>
                        <div class="card-footer">
                            <a href="/contact" class="btn btn-sm btn-primary">Cere Ofertă</a>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <!-- Service Details -->
        <section class="service-details">
            <h2>Ce Este Inclus</h2>
            <div class="details-grid">
                <div class="detail-box">
                    <h4>Curățarea Apartamentelor</h4>
                    <ul>
                        <li>✓ Curățare bucătărie</li>
                        <li>✓ Curățare baie</li>
                        <li>✓ Camere și spații de locuit</li>
                        <li>✓ Curățare podele</li>
                        <li>✓ Praf și aspirare</li>
                    </ul>
                </div>
                <div class="detail-box">
                    <h4>Curățarea Caselor</h4>
                    <ul>
                        <li>✓ Curățare profundă toate camerele</li>
                        <li>✓ Aparate bucătărie</li>
                        <li>✓ Echipamente baie</li>
                        <li>✓ Covoase și podele</li>
                        <li>✓ Ferestre și soclu</li>
                    </ul>
                </div>
                <div class="detail-box">
                    <h4>Curățarea Birourilor</h4>
                    <ul>
                        <li>✓ Stații de lucru</li>
                        <li>✓ Săli de conferință</li>
                        <li>✓ Facilități sanitare</li>
                        <li>✓ Mentenanță podea</li>
                        <li>✓ Îndepărtare gunoi</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Package Table -->
        <section class="package-section">
            <h2>Pachete de Servicii</h2>
            <table class="package-table">
                <thead>
                    <tr>
                        <th>Tip Serviciu</th>
                        <th>Apartament</th>
                        <th>Casă</th>
                        <th>Birou</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="service-name">Curățare Unică</td>
                        <td>$50/oră</td>
                        <td>$60/oră</td>
                        <td>$70/oră</td>
                    </tr>
                    <tr>
                        <td class="service-name">Serviciu Săptămânal</td>
                        <td>$180/lună</td>
                        <td>$240/lună</td>
                        <td>$350/lună</td>
                    </tr>
                    <tr>
                        <td class="service-name">Serviciu Pe Două Săptămâni</td>
                        <td>$90/lună</td>
                        <td>$120/lună</td>
                        <td>$175/lună</td>
                    </tr>
                    <tr>
                        <td class="service-name">Curățare Profundă Lunară</td>
                        <td>$200</td>
                        <td>$300</td>
                        <td>$400</td>
                    </tr>
                    <tr>
                        <td class="service-name">Curățare la Mutare</td>
                        <td colspan="2">$400-800</td>
                        <td>Ofertă</td>
                    </tr>
                </tbody>
            </table>
        </section>

        <!-- CTA -->
        <section class="cta">
            <h2>Să Curățim Spațiul Vostru!</h2>
            <p>Contactați-ne pentru o consultație gratuită și ofertă personalizată</p>
            <a href="/contact" class="btn btn-large">Rezervați Acum</a>
        </section>
    </main>

    <%- include('includes/footer.ejs') %>

    <script src="/js/main.js"></script>
</body>
</html>
